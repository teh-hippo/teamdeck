{
	"name": "teamdeck",
	"version": "0.1.0",
	"description": "Control Microsoft Teams meetings from an Elgato Stream Deck, using the Teams third-party app API. Not affiliated with Microsoft or Elgato.",
	"author": "teh-hippo",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/teh-hippo/teamdeck.git"
	},
	"type": "module",
	"scripts": {
		"build": "rollup -c",
		"watch": "rollup -c -w --watch.onEnd=\"streamdeck restart io.github.teh-hippo.teamdeck\"",
		"icons": "node tools/gen-icons.mjs",
		"validate": "streamdeck validate io.github.teh-hippo.teamdeck.sdPlugin",
		"pack": "streamdeck pack io.github.teh-hippo.teamdeck.sdPlugin",
		"proof": "node tools/proof-gate.mjs",
		"secret-scan": "node tools/secret-scan.mjs",
		"hooks": "node tools/install-hooks.mjs",
		"prepare": "node tools/install-hooks.mjs"
	},
	"devDependencies": {
		"@elgato/cli": "^1.7.4",
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^15.2.2",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.1.0",
		"@tsconfig/node20": "^20.1.2",
		"@types/node": "~24.1.0",
		"rollup": "^4.0.2",
		"tslib": "^2.6.2",
		"typescript": "^5.2.2"
	},
	"dependencies": {
		"@elgato/streamdeck": "^2.1.0"
	}
}
